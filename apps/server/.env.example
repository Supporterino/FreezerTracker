# FreezerMan Server — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# For Docker Compose: use "db" as the host (matches the service name)
# For manual setup: use "localhost" or your database host
DATABASE_URL=postgresql://postgres:password@db:5432/freezer_tracker

# JWT signing secrets — generate strong random values for each:
#   openssl rand -base64 32
# These MUST be different from each other.
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Optional ────────────────────────────────────────────────────────────────

# Access token lifetime (default: 15m)
# JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime (default: 30d)
# JWT_REFRESH_EXPIRES_IN=30d

# Comma-separated list of allowed CORS origins
# Set this to the URL where your client connects from
# ALLOWED_ORIGINS=http://localhost:1420

# Base URL for QR invite links
# APP_BASE_URL=http://localhost:3000

# Server listen port (default: 3000)
# PORT=3000

# Environment mode: development | production | test
# Swagger UI is disabled in production
# NODE_ENV=development
