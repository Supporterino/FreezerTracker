{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/guidelines.md",
    "docs/security.md",
    ".opencode/instructions/ctx-host-first.md"
  ],
  "mcp": {
    "ctx": {
      "command": [
        "/usr/local/bin/ctx",
        "--repo-root",
        "/Users/supporterino/repos/FreezerTracker",
        "mcp",
        "stdio"
      ],
      "enabled": true,
      "type": "local"
    },
    "mantine": {
      "command": [
        "npx",
        "-y",
        "@mantine/mcp-server"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": "allow",
    "codesearch": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "read": "allow",
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "provider": {
    "lmstudio": {
      "models": {
        "mistralai/devstral-small-2-2512": {
          "name": "Devstral Small 2"
        },
        "zai-org/glm-4.6v-flash": {
          "name": "GLM 4.6v Flash"
        }
      }
    }
  }
}
