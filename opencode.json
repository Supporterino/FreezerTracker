{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow"
  },
  "mcp": {
    "mantine": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@mantine/mcp-server"]
    }
  },
  "provider": {
    "lmstudio": {
      "models": {
        "zai-org/glm-4.6v-flash": {
          "name": "GLM 4.6v Flash"
        },
        "mistralai/devstral-small-2-2512": {
          "name": "Devstral Small 2"
        }
      }
    }
  }
}